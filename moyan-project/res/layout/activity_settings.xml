<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#263238">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ 设置"
            android:textSize="28sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- 帧率选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📺 刷新率"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rg_fps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/rb_30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30Hz"
                android:textColor="#B0BEC5"/>

            <RadioButton
                android:id="@+id/rb_60"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60Hz"
                android:textColor="#B0BEC5"
                android:layout_marginStart="12dp"/>

            <RadioButton
                android:id="@+id/rb_90"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90Hz"
                android:textColor="#B0BEC5"
                android:layout_marginStart="12dp"/>

            <RadioButton
                android:id="@+id/rb_120"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120Hz"
                android:textColor="#B0BEC5"
                android:layout_marginStart="12dp"/>

            <RadioButton
                android:id="@+id/rb_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动"
                android:textColor="#FFD700"
                android:layout_marginStart="12dp"/>
        </RadioGroup>

        <TextView
            android:id="@+id/tv_fps_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前: 自动(最高)"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- 画质 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 画质档位 (1-7)"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/sb_quality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6"
            android:progress="3"
            android:progressDrawable="@android:drawable/scrubber_progress"
            android:thumb="@android:drawable/scrubber_control"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_quality_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- 音量控制 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊 音量控制"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="背景音乐"
            android:textColor="#B0BEC5"
            android:textSize="14sp"/>

        <SeekBar
            android:id="@+id/sb_bgm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="出牌音效"
            android:textColor="#B0BEC5"
            android:textSize="14sp"/>

        <SeekBar
            android:id="@+id/sb_sfx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="语音播报"
            android:textColor="#B0BEC5"
            android:textSize="14sp"/>

        <SeekBar
            android:id="@+id/sb_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="24dp"/>

        <!-- 开关选项 -->
        <Switch
            android:id="@+id/sw_card_counter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 记牌器"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <Switch
            android:id="@+id/sw_night_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌙 夜间护眼模式"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- 开发者选项 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 开发者选项"
            android:textSize="18sp"
            android:textColor="#FF8A65"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍀 我方运气值 (影响发牌) 0~100%"
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/sb_luck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_luck_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ 运气值越高，你摸到高牌的概率越大"
            android:textColor="#FF8A65"
            android:textSize="12sp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</ScrollView>
